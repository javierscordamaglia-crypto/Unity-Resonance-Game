# =========================
# UNITY .gitignore (clean)
# =========================

# Unity folders
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/

# Memory captures
[Mm]emoryCaptures/

# Recordings
[Rr]ecordings/

# Asset Store tools (optional)
# Assets/AssetStoreTools*

# JetBrains Rider
Assets/Plugins/Editor/JetBrains*
*.DotSettings.user

# Visual Studio / IDE
.vs/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generated meta (debug/crash)
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crash reports
sysinfo.txt
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Blender temp files
*.blend1
*.blend1.meta

# Addressables
ServerData/
Assets/StreamingAssets/aa*
Assets/AddressableAssetsData/*/*.bin*
Assets/Addressables_Temp*

# Visual Scripting
Assets/Unity.VisualScripting.Generated/

# Test scenes
Assets/InitTestScene*.unity*

# OS files
.DS_Store
Thumbs.db